# Backend - Environment Variables Example
# Copy this file to .env.local for local development and .env.production for production
# Then fill in the actual values

# Server Port (optional, default 5000)
PORT=5000

# MongoDB Connection URI
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database-name

# JWT Secret Key (make this a long, random string in production!)
JWT_SECRET=your_jwt_secret_key_here
